# Supabase — 在 https://supabase.com 创建项目后填入
# URL 填项目根地址，不要带 /rest/v1/
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# 可选：用于 npm run seed:admin 创建管理员账号
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DeepSeek API Key 不要写在这里（会暴露到前端）。
# 请部署 Supabase Edge Function 后，在 Dashboard → Edge Functions → Secrets
# 或 CLI 执行：supabase secrets set DEEPSEEK_API_KEY=sk-xxx
# 函数名称默认 smart-function，可在 .env.local 覆盖：
# NEXT_PUBLIC_WORK_SUMMARY_FUNCTION=smart-function

# 密码重置邮件 Redirect URLs（Supabase → Authentication → URL Configuration）：
# http://localhost:3000/reset-password/
# https://driftmrd.github.io/management_system/reset-password/
